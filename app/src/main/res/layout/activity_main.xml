<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_dark"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/noteTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/frequencyTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/frequency_placeholder"
        android:textSize="20sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Tuner Dial -->
    <FrameLayout
        android:id="@+id/tunerDial"
        android:layout_width="300dp"
        android:layout_height="150dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/tuner_dial_background">

        <!-- Center line -->
        <View
            android:layout_width="4dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:background="@color/text_primary" />

        <!-- Moving tuning needle -->
        <View
            android:id="@+id/needleIndicator"
            android:layout_width="6dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:background="@color/tuner_green"
            android:visibility="gone" />

        <!-- Flat and Sharp labels -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="♭"
            android:textSize="16sp"
            android:textColor="@color/tuner_red"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="40dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="♯"
            android:textSize="16sp"
            android:textColor="@color/tuner_red"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="260dp" />

    </FrameLayout>

    <TextView
        android:id="@+id/accuracyTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="18sp"
        android:textColor="@color/tuner_yellow"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/startButton"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="@string/button_start"
        android:textSize="18sp"
        android:background="@drawable/button_background"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/stopButton"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="@string/button_stop"
        android:textSize="18sp"
        android:background="@drawable/button_background"
        android:textColor="@color/text_primary"
        android:visibility="gone" />

    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_idle"
        android:textSize="16sp"
        android:textColor="@color/text_muted"
        android:layout_marginTop="16dp" />
</LinearLayout>
